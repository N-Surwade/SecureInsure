@container (min-width: 28rem) {
  .\@md\:block { display: block; }
  .\@md\:flex-1 { flex: 1 1 0%; }
  .\@md\:basis-1\/3 { flex-basis: 33.3333%; }
  .\@md\:flex-row { flex-direction: row; }
  .\@md\:items-center { align-items: center; }
  .\@md\:gap-2 { gap: 0.5rem; }
}

@container pricing (min-width: 40rem) {
  .\@\[40rem\]\/pricing\:col-span-6 { grid-column: span 6 / span 6; }
  .\@\[40rem\]\/pricing\:row-span-5 { grid-row: span 5 / span 5; }
  .\@\[40rem\]\/pricing\:mb-5 { margin-bottom: 1.25rem; }
  .\@\[40rem\]\/pricing\:grid-cols-12 { grid-template-columns: repeat(12, m=
inmax(0px, 1fr)); }
  .\@\[40rem\]\/pricing\:grid-rows-subgrid { grid-template-rows: subgrid; }
  .\@\[40rem\]\/pricing\:gap-0 { gap: 0px; }
  .\@\[40rem\]\/pricing\:gap-x-5 { column-gap: 1.25rem; }
}

@container (min-width: 42rem) {
  .\@2xl\:flex { display: flex; }
  .\@2xl\:hidden { display: none; }
}

@container (min-width: 48rem) {
  .\@3xl\:p-9 { padding: 2.25rem; }
  .\@3xl\:px-10 { padding-left: 2.5rem; padding-right: 2.5rem; }
}

